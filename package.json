{
  "name": "ts-ultrastrict-ai",
  "version": "0.1.0",
  "description": "Ultra-strict TypeScript project template with full AI agent tooling",
  "private": false,
  "type": "module",
  "packageManager": "pnpm@10.12.1",
  "scripts": {
    "build": "tsc -p tsconfig.src.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix --max-warnings 0",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit -p tsconfig.src.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.5.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^6.0.0",
    "vite-plugin-doctest": "^2.0.0",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "prettier --check",
      "eslint --max-warnings 0"
    ],
    "*.{json,md,html,css}": [
      "prettier --check"
    ]
  }
}
