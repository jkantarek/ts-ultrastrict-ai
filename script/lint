#!/usr/bin/env bash
# script/lint: Run all linting and formatting checks.
# https://github.com/github/scripts-to-rule-them-all

set -euo pipefail

cd "$(dirname "$0")/.."

if [ "${1:-}" = "--fix" ]; then
  echo "==> Auto-fixing lint issues..."
  pnpm lint:fix
  echo "==> Auto-formatting files..."
  pnpm format
else
  echo "==> Running TypeScript type check..."
  pnpm typecheck

  echo "==> Running ESLint (zero warnings)..."
  pnpm lint

  echo "==> Checking formatting..."
  pnpm format:check

  echo ""
  echo "All checks passed."
fi
