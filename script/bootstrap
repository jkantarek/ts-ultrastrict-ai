#!/usr/bin/env bash
# script/bootstrap: Resolve all dependencies and prepare the project for development.
# https://github.com/github/scripts-to-rule-them-all

set -euo pipefail

cd "$(dirname "$0")/.."

echo "==> Checking for pnpm..."
if ! command -v pnpm &>/dev/null; then
  echo "ERROR: pnpm is not installed. Install it via:"
  echo "  npm install -g pnpm"
  echo "  or: https://pnpm.io/installation"
  exit 1
fi

echo "==> Installing dependencies..."
pnpm install

echo "==> Setting up git hooks..."
pnpm prepare

echo "==> Verifying quality gates..."
pnpm typecheck
pnpm lint
pnpm format:check
pnpm test

echo ""
echo "Bootstrap complete. You're ready to develop!"
