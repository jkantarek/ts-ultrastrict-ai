#!/usr/bin/env bash
# script/test: Run the test suite.
# https://github.com/github/scripts-to-rule-them-all

set -euo pipefail

cd "$(dirname "$0")/.."

if [ "${1:-}" = "--coverage" ]; then
  echo "==> Running tests with coverage..."
  pnpm test:coverage
elif [ "${1:-}" = "--watch" ]; then
  echo "==> Running tests in watch mode..."
  pnpm test:watch
elif [ "${1:-}" = "--ui" ]; then
  echo "==> Opening test UI..."
  pnpm test:ui
else
  echo "==> Running tests..."
  pnpm test
fi
