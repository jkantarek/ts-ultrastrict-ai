#!/usr/bin/env bash
# script/ci: Run the full continuous integration quality gate suite.
# https://github.com/github/scripts-to-rule-them-all
#
# Mirrors exactly what .github/workflows/ci.yml runs so you can validate
# locally before pushing.

set -euo pipefail

cd "$(dirname "$0")/.."

if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
  echo "Usage: script/ci [options]"
  echo ""
  echo "Runs the complete CI quality gate suite locally."
  echo "Mirrors .github/workflows/ci.yml — if this passes, CI will pass."
  echo ""
  echo "Gates (run in order):"
  echo "  1. TypeScript type check   pnpm typecheck"
  echo "  2. ESLint zero warnings    pnpm lint"
  echo "  3. Prettier format check   pnpm format:check"
  echo "  4. Tests + coverage        pnpm test:coverage  (must be >=98%)"
  echo ""
  echo "Options:"
  echo "  -h, --help   Show this help message"
  echo "  --no-color   Disable colored output"
  exit 0
fi

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RESET='\033[0m'

if [[ "${1:-}" == "--no-color" ]]; then
  RED=''
  GREEN=''
  YELLOW=''
  RESET=''
fi

FAILED=()

run_gate() {
  local name="$1"
  local cmd="$2"
  echo ""
  echo "==> ${name}..."
  if eval "$cmd"; then
    echo -e "${GREEN}PASS${RESET} ${name}"
  else
    echo -e "${RED}FAIL${RESET} ${name}"
    FAILED+=("$name")
  fi
}

run_gate "TypeScript type check" "pnpm typecheck"
run_gate "ESLint (zero warnings)"  "pnpm lint"
run_gate "Prettier format check"   "pnpm format:check"
run_gate "Tests + coverage (>=98%)" "pnpm test:coverage"

echo ""
if [ ${#FAILED[@]} -eq 0 ]; then
  echo -e "${GREEN}All gates passed. Ready to push.${RESET}"
  exit 0
else
  echo -e "${RED}Failed gates:${RESET}"
  for gate in "${FAILED[@]}"; do
    echo -e "  ${YELLOW}✗${RESET} ${gate}"
  done
  exit 1
fi
